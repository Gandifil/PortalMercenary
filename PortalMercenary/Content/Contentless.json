{
  "exclude": [
    "obj/*",
    "bin/*",
    "*/Ex*.png",
    "Tiled/*.png"
  ],
  "logSkipped": true,
  "references": ["MonoGame.Extended.Content.Pipeline", "FreeTexturePackerPipeline", "FreeTexturePackerReader"],
  "overrides": {
    "*/Copy.*": {
      "copy": true
    },
    "*/*set.json": {
      "importer": "TexturePackerJsonImporter",
      "processor": "TexturePackerProcessor"
    },
    "*/*.json": {
      "copy": true
    },
    "*/*.ogg": {
      "importer": "OggImporter",
      "processor": "SongProcessor"
    },
    "*/*.png": {
      "processorParams": {
        "TextureFormat": "NoChange"
      }
    }
  }
}